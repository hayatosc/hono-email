{
  "name": "hono-email",
  "version": "0.4.0",
  "description": "A lightweight, type-safe email template engine for Hono, powered by Hono JSX.",
  "keywords": [
    "email",
    "hono",
    "jsx",
    "react",
    "tailwind",
    "template"
  ],
  "homepage": "https://github.com/hayatosc/hono-email#readme",
  "bugs": {
    "url": "https://github.com/hayatosc/hono-email/issues"
  },
  "license": "MIT",
  "author": "hayatosc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hayatosc/hono-email.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter/index.d.ts",
      "import": "./dist/adapter/index.js"
    },
    "./smtp": {
      "types": "./dist/adapter/smtp/index.d.ts",
      "import": "./dist/adapter/smtp/index.js"
    },
    "./smtp/*": {
      "types": "./dist/adapter/platform/*/smtp.d.ts",
      "import": "./dist/adapter/platform/*/smtp.js"
    },
    "./cloudflare": {
      "types": "./dist/adapter/cloudflare/index.d.ts",
      "import": "./dist/adapter/cloudflare/index.js"
    },
    "./cloudflare/workers": {
      "types": "./dist/adapter/platform/cloudflare/index.d.ts",
      "import": "./dist/adapter/platform/cloudflare/index.js"
    },
    "./cloudflare/rest": {
      "types": "./dist/adapter/cloudflare/rest.d.ts",
      "import": "./dist/adapter/cloudflare/rest.js"
    },
    "./provider": {
      "types": "./dist/adapter/provider/index.d.ts",
      "import": "./dist/adapter/provider/index.js"
    },
    "./resend": {
      "types": "./dist/adapter/resend/index.d.ts",
      "import": "./dist/adapter/resend/index.js"
    },
    "./sendgrid": {
      "types": "./dist/adapter/sendgrid/index.d.ts",
      "import": "./dist/adapter/sendgrid/index.js"
    },
    "./postmark": {
      "types": "./dist/adapter/postmark/index.d.ts",
      "import": "./dist/adapter/postmark/index.js"
    },
    "./mailgun": {
      "types": "./dist/adapter/mailgun/index.d.ts",
      "import": "./dist/adapter/mailgun/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test": "bun test ./src"
  },
  "dependencies": {
    "decode-named-character-reference": "^1.3.0",
    "htmlrewriter": "^0.0.13"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20260424.1",
    "@types/bun": "^1.3.12",
    "@types/css-tree": "^2.3.11",
    "css-tree": "^3.1.0",
    "hono": "^4.12.14",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
