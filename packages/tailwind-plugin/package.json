{
  "name": "@hono-email/tailwind-plugin",
  "version": "0.7.0",
  "description": "Bundler plugin for Tailwind integration with hono-email.",
  "keywords": [
    "email",
    "hono",
    "tailwind",
    "unplugin",
    "vite"
  ],
  "homepage": "https://github.com/hayatosc/hono-email#readme",
  "bugs": {
    "url": "https://github.com/hayatosc/hono-email/issues"
  },
  "license": "MIT",
  "author": "hayatosc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hayatosc/hono-email.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.mts",
        "default": "./dist/vite.mjs"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/rollup.d.mts",
        "default": "./dist/rollup.mjs"
      },
      "require": {
        "types": "./dist/rollup.d.cts",
        "default": "./dist/rollup.cjs"
      }
    },
    "./rolldown": {
      "import": {
        "types": "./dist/rolldown.d.mts",
        "default": "./dist/rolldown.mjs"
      },
      "require": {
        "types": "./dist/rolldown.d.cts",
        "default": "./dist/rolldown.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.mts",
        "default": "./dist/webpack.mjs"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      }
    },
    "./rspack": {
      "import": {
        "types": "./dist/rspack.d.mts",
        "default": "./dist/rspack.mjs"
      },
      "require": {
        "types": "./dist/rspack.d.cts",
        "default": "./dist/rspack.cjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esbuild.d.mts",
        "default": "./dist/esbuild.mjs"
      },
      "require": {
        "types": "./dist/esbuild.d.cts",
        "default": "./dist/esbuild.cjs"
      }
    },
    "./farm": {
      "import": {
        "types": "./dist/farm.d.mts",
        "default": "./dist/farm.mjs"
      },
      "require": {
        "types": "./dist/farm.d.cts",
        "default": "./dist/farm.cjs"
      }
    },
    "./bun": {
      "import": {
        "types": "./dist/bun.d.mts",
        "default": "./dist/bun.mjs"
      },
      "require": {
        "types": "./dist/bun.d.cts",
        "default": "./dist/bun.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.mts",
        "default": "./dist/types.mjs"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src"
  },
  "dependencies": {
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "hono-email": "workspace:*"
  },
  "peerDependencies": {
    "hono-email": ">=0.4.0 <1.0.0"
  }
}
