{
  "name": "@hono-email/preview",
  "version": "0.5.1",
  "description": "Live preview server for hono-email templates with real-time props editing.",
  "keywords": [
    "cli",
    "dev",
    "email",
    "hono",
    "preview"
  ],
  "homepage": "https://github.com/hayatosc/hono-email#readme",
  "bugs": {
    "url": "https://github.com/hayatosc/hono-email/issues"
  },
  "license": "MIT",
  "author": "hayatosc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hayatosc/hono-email.git"
  },
  "bin": {
    "hono-email": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown && vite build --config vite.client.config.ts",
    "dev": "tsdown && node ./dist/cli.mjs preview --dir test-emails",
    "typecheck": "tsgo --noEmit",
    "typecheck:compat": "tsc --noEmit",
    "test": "bun test ./src"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@tailwindcss/vite": "^4.2.2",
    "citty": "^0.1.6",
    "hono": "^4.12.14",
    "tailwindcss": "^4.2.2",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@hono-email/tailwind-plugin": "workspace:*",
    "@types/bun": "^1.3.12",
    "hono-email": "workspace:*"
  },
  "peerDependencies": {
    "hono-email": ">=0.4.0 <1.0.0"
  }
}
