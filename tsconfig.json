{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "hono-email": [
        "./src/index.ts"
      ],
      "hono-email/vite": [
        "./src/vite.ts"
      ]
    },
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "bun"
    ]
  },
  "include": [
    "src",
    "tests",
    "examples"
  ]
}
