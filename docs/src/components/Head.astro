---
import Default from '@astrojs/starlight/components/Head.astro';

const { entry } = Astro.locals.starlightRoute;
const rawTitle = entry?.data.title ?? 'hono-email';
const title = rawTitle === 'hono-email' ? rawTitle : `${rawTitle} | hono-email`;
const description = entry?.data.description || 'Render, validate, and send HTML email and plain text from hono/jsx.';

const ogParams = new URLSearchParams({ title, description });
const devOgUrl = `/api/og.png?${ogParams.toString()}`;

const pagePath = Astro.url.pathname;
const ogFile = pagePath === '/' ? 'index.png' : `${pagePath.replace(/^\/|\/$/g, '')}.png`;
const prodOgUrl = Astro.site
  ? new URL(`/og/${ogFile}`, Astro.site).toString()
  : `/og/${ogFile}`;

const ogImageUrl = import.meta.env.DEV ? devOgUrl : prodOgUrl;
---

<Default {...Astro.props} />

<meta property="og:image" content={ogImageUrl} />
<meta property="twitter:image" content={ogImageUrl} />
