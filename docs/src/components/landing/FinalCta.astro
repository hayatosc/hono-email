---
import GetStartedButton from './GetStartedButton.astro'
import InstallCommand from './InstallCommand.svelte'
---

<section>
  <div class="inner">
    <div class="card">
      <h2 class="title">Send your first email in minutes.</h2>
      <div class="cta">
        <GetStartedButton />
        <InstallCommand client:idle />
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding-block: clamp(3rem, 7vw, 5rem);
  }
  .inner {
    max-width: var(--lp-maxw);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
  }
  .card {
    position: relative;
    text-align: center;
    padding: clamp(2.5rem, 6vw, 4rem) 1.5rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 1.25rem;
    background:
      radial-gradient(70% 120% at 50% 0%, var(--lp-accent-soft), transparent 70%),
      var(--sl-color-bg-inline-code);
  }
  .title {
    margin: 0 auto;
    border: 0;
    padding: 0;
    line-height: 1.1;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--sl-color-white);
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.8rem;
  }

  @media (max-width: 40rem) {
    .cta {
      flex-direction: column;
    }
  }
</style>
