---
import Section from './Section.astro'

const adapters = ['SMTP', 'Resend', 'SendGrid', 'Postmark', 'Mailgun', 'Cloudflare Email']
---

<Section kicker="Transports" title="Send through the provider you already use.">
  <ul class="adapters">
    {adapters.map((a) => <li class="adapter">{a}</li>)}
  </ul>
</Section>

<style>
  .adapters {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }
  .adapter {
    padding: 0.5rem 1rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 2rem;
    font-family: var(--sl-font-mono);
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .adapter:hover {
    border-color: var(--lp-accent);
    color: var(--sl-color-white);
  }
</style>
