---
import Default from '@astrojs/starlight/components/PageTitle.astro';

const { url } = Astro;
const pathname = url.pathname.replace(/\/$/, '');
const markdownUrl = pathname ? `${pathname}.md` : '/index.md';
---

<Default {...Astro.props} />

<div class="markdown-available">
  <a href={markdownUrl} class="md-badge">
    <!-- Markdown mark logo -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 208 128"
      aria-hidden="true"
      class="md-icon"
    >
      <rect width="198" height="118" x="5" y="5" ry="10" stroke="currentColor" stroke-width="10" fill="none"/>
      <path fill="currentColor" d="M30 98V30h20l20 25 20-25h20v68H90V59L70 84 50 59v39zm125 0l-30-33h20V30h20v35h20z"/>
    </svg>
    View as Markdown
  </a>
</div>

<style>
  .markdown-available {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .md-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.2em 0.65em;
    border-radius: 0.3rem;
    border: 1.5px solid #888;
    background: #fff;
    color: #111;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    line-height: 1.6;
    transition: opacity 0.15s;
  }

  .md-badge:hover {
    opacity: 0.75;
    text-decoration: underline;
  }

  .md-icon {
    width: 1.25em;
    height: auto;
    flex-shrink: 0;
  }
</style>
