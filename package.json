{
  "name": "hono-email",
  "version": "0.1.0",
  "description": "A lightweight, type-safe email template engine for Hono, powered by Hono JSX.",
  "type": "module",
  "author": "Hayato Shiozaki <hayato@shiozaki.io>",
  "license": "MIT",
  "homepage": "https://github.com/hayatosc/hono-email#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hayatosc/hono-email.git"
  },
  "bugs": {
    "url": "https://github.com/hayatosc/hono-email/issues"
  },
  "keywords": [
    "hono",
    "email",
    "template",
    "jsx",
    "react",
    "tailwind"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/unplugin.d.ts",
      "import": "./dist/unplugin.js"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "format": "oxfmt --write .",
    "lint": "oxlint --deny-warnings .",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "css-tree": "^3.1.0",
    "htmlrewriter": "^0.0.13",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/css-tree": "^2.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "bun-plugin-dts": "^0.4.0",
    "hono": "^4.12.14",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.12",
  "patchedDependencies": {
    "css-tree@3.2.1": "patches/css-tree@3.2.1.patch",
    "mdast-util-from-markdown@2.0.3": "patches/mdast-util-from-markdown@2.0.3.patch",
    "micromark@4.0.2": "patches/micromark@4.0.2.patch"
  }
}
