{
  "name": "hono-email",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./unplugin": {
      "types": "./src/unplugin.ts",
      "import": "./dist/unplugin.js"
    },
    "./vite": {
      "types": "./src/vite.ts",
      "import": "./dist/vite.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/unplugin.ts ./src/vite.ts --outdir dist --format esm --target node",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/css-tree": "^2.3.11",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "css-tree": "^3.1.0",
    "hono": "^4.12.14",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unifont": "^0.7.4",
    "unplugin": "^3.0.0"
  },
  "patchedDependencies": {
    "css-tree@3.2.1": "patches/css-tree@3.2.1.patch"
  }
}
