{
  "name": "hono-email-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "changeset": "changeset",
    "version": "bun run --filter hono-email update-caniemail && changeset version && bun run format",
    "release": "changeset publish",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:types": "oxlint --type-aware .",
    "test": "bun test --path-ignore-patterns='_build' packages/core/src packages/tailwind-plugin/src packages/preview/src docs/src",
    "test:coverage": "bun test --coverage --path-ignore-patterns='_build' packages/core/src packages/tailwind-plugin/src packages/preview/src docs/src",
    "test:runtime": "bun run test:runtime:node && bun run test:runtime:deno && bun run test:runtime:bun && bun run test:runtime:cloudflare",
    "test:runtime:node": "tsx --test runtime-tests/node/*.test.ts",
    "test:runtime:deno": "deno test --allow-net --allow-read runtime-tests/deno",
    "test:runtime:bun": "bun test runtime-tests/bun",
    "test:runtime:cloudflare": "vitest --run --config runtime-tests/cloudflare/vitest.config.ts",
    "typecheck": "bun run --filter './packages/*' typecheck",
    "typecheck:compat": "bun run --filter './packages/*' typecheck:compat"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20260424.1",
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "hono": "^4.12.14",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsdown": "^0.21.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unplugin": "^3.0.0",
    "unplugin-isolated-decl": "^0.16.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.12",
  "patchedDependencies": {
    "mdast-util-from-markdown@2.0.3": "patches/mdast-util-from-markdown@2.0.3.patch",
    "micromark@4.0.2": "patches/micromark@4.0.2.patch",
    "decode-named-character-reference@1.3.0": "patches/decode-named-character-reference@1.3.0.patch"
  }
}
