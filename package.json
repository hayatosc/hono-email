{
  "name": "hono-email",
  "version": "0.3.2",
  "description": "A lightweight, type-safe email template engine for Hono, powered by Hono JSX.",
  "keywords": [
    "email",
    "hono",
    "jsx",
    "react",
    "tailwind",
    "template"
  ],
  "homepage": "https://github.com/hayatosc/hono-email#readme",
  "bugs": {
    "url": "https://github.com/hayatosc/hono-email/issues"
  },
  "license": "MIT",
  "author": "hayatosc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hayatosc/hono-email.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/types/adapter/index.d.ts",
      "import": "./dist/adapter/index.js"
    },
    "./smtp": {
      "types": "./dist/types/adapter/smtp/index.d.ts",
      "import": "./dist/adapter/smtp/index.js"
    },
    "./smtp/*": {
      "types": "./dist/types/adapter/platform/*/smtp.d.ts",
      "import": "./dist/adapter/platform/*/smtp.js"
    },
    "./cloudflare-email": {
      "types": "./dist/types/adapter/cloudflare-email/index.d.ts",
      "import": "./dist/adapter/cloudflare-email/index.js"
    },
    "./cloudflare-email/cloudflare": {
      "types": "./dist/types/adapter/platform/cloudflare/email-service.d.ts",
      "import": "./dist/adapter/platform/cloudflare/email-service.js"
    },
    "./cloudflare-email/rest": {
      "types": "./dist/types/adapter/cloudflare-email/rest.d.ts",
      "import": "./dist/adapter/cloudflare-email/rest.js"
    },
    "./plugin": {
      "types": "./dist/types/unplugin.d.ts",
      "import": "./dist/unplugin.js",
      "require": "./dist/unplugin.cjs"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware .",
    "test": "bun test ./src",
    "test:runtime": "bun run test:runtime:node && bun run test:runtime:deno && bun run test:runtime:bun && bun run test:runtime:cloudflare",
    "test:runtime:node": "node --test runtime-tests/node/*.test.ts",
    "test:runtime:deno": "deno test --allow-net --allow-read runtime-tests/deno",
    "test:runtime:bun": "bun test runtime-tests/bun",
    "test:runtime:cloudflare": "vitest --run --config runtime-tests/cloudflare/vitest.config.ts",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "htmlrewriter": "^0.0.13"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20260424.1",
    "@types/bun": "^1.3.12",
    "@types/css-tree": "^2.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "css-tree": "^3.1.0",
    "hono": "^4.12.14",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "unplugin": "^3.0.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.12",
  "patchedDependencies": {
    "css-tree@3.2.1": "patches/css-tree@3.2.1.patch",
    "mdast-util-from-markdown@2.0.3": "patches/mdast-util-from-markdown@2.0.3.patch",
    "micromark@4.0.2": "patches/micromark@4.0.2.patch"
  }
}
